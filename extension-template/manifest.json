{
  "manifest_version": 3,
  "name": "AniCal — Anime Schedule",
  "version": "1.1.0",
  "description": "Live anime airing calendar with JST→local time, favorites, weekly schedule, and airing notifications. Powered by MyAnimeList.",
  "action": {
    "default_popup": "index.html",
    "default_icon": {
      "16": "icon.png",
      "48": "icon.png",
      "128": "icon.png"
    }
  },
  "icons": {
    "16": "icon.png",
    "48": "icon.png",
    "128": "icon.png"
  },
  "background": {
    "service_worker": "background.js"
  },
  "permissions": ["alarms", "notifications", "storage"],
  "host_permissions": ["https://api.jikan.moe/*"]
}
